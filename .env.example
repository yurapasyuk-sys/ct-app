# Telegram bot token from @BotFather. Do not commit real tokens.
TELEGRAM_BOT_TOKEN=

# Destination chat id: your user chat, group, channel, or supergroup id.
# This is not the bot id. For supergroups it usually starts with -100...
TELEGRAM_CHAT_ID=

# Optional live signal monitor settings.
SIGNAL_SYMBOLS=AUDUSD,EURUSD,GBPUSD,USDJPY,GER40
SIGNAL_POLL_MS=300000
SIGNAL_MAX_SIGNAL_AGE_MINUTES=90
SIGNAL_DATA_DIR=logs

# Manual MT5 sizing shown on Forex signals. Defaults match a fixed 1% risk
# ($50) on a $5,000 USD account and standard 100,000-unit Forex contracts.
SIGNAL_ACCOUNT_BALANCE_USD=5000
SIGNAL_RISK_PER_TRADE_PCT=1
SIGNAL_FX_CONTRACT_SIZE=100000
SIGNAL_FX_LOT_STEP=0.01
SIGNAL_FX_MIN_LOT=0.01
SIGNAL_FX_MAX_LOT=100

# Set to 1 to print/log signals without sending Telegram messages.
SIGNAL_DRY_RUN=0
